package Programs;

class Box<T> {

    private T item;

    public void setItem(T item) {
        this.item = item;
    }

    public T getItem() {
        return item;
    }
}

class Utility {

    public static <T> void printArray(T[] arr) {
        for (T element : arr) {
            System.out.print(element + " ");
        }
        System.out.println();
    }
}

public class SimpleGenerics {

    public static void main(String[] args) {

        Box<String> stringBox = new Box<>();
        stringBox.setItem("Practice Java");
        System.out.println("String Box: " + stringBox.getItem());

        Box<Integer> intBox = new Box<>();
        intBox.setItem(100);
        System.out.println("Integer Box: " + intBox.getItem());

        Integer[] nums = {1, 2, 3, 4, 5};
        String[] names = {"Sachin", "Nandini", "Ranjith"};

        System.out.print("Numbers: ");
        Utility.printArray(nums);

        System.out.print("Names: ");
        Utility.printArray(names);
    }
}

